  }

  /* ── Image column ──────────────────────────────────────────── */
  .entry-image-wrap {
    position: relative;
    width: fit-content;
    background: transparent;
  }
  .image-glow {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(127, 230, 220, 0.2) 0%, transparent 70%);
