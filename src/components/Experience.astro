    z-index: 0;
    pointer-events: none;
  }
  .entry-img {
    width: 440px;
    max-width: 100%;
    object-fit: contain;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    display: block;
    position: relative;
    z-index: 1;
    transition: transform 0.4s ease;
  }

  .timeline-entry:hover .entry-img {
    transform: scale(1.03);
  }

  /* ── Annotation ────────────────────────────────────────────── */
  .annotation {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    pointer-events: none;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  .annotation-right {
    align-items: flex-end;
    text-align: right;
    /* Position below the image */
    padding-left: 50%;
    padding-right: 0;
  }
  .annotation-left {
    align-items: flex-start;
    text-align: left;
    /* Position below the image */
    padding-right: 50%;
    padding-left: 0;
  }

  .annotation-arrow {
    width: 50px;
    height: 42px;
  }
  .annotation-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.78rem;
    font-style: italic;
    color: #777;
    line-height: 1.4;
  }
  .annotation-highlight {
    color: var(--primary);
    font-weight: 700;
    font-style: italic;
  }



  /* ── Scroll-reveal animations ──────────────────────────────── */
  .timeline-entry-wrapper.js-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-entry-wrapper.is-visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .exp-header {
      margin-bottom: 3.5rem;
    }
    /* .timeline {
      padding-left: 1rem;
      padding-right: 1rem;
    } */
    .timeline-entry-wrapper {
      margin-bottom: 4rem;
    }
    .main-path {
      display: none;
    }
    .path-dot-group {
      display: none !important;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 12px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: repeating-linear-gradient(
        to bottom,
        #e2bebc 0px,
        #e2bebc 6px,
        transparent 6px,
        transparent 14px
      );
      z-index: 0;
    }
    .timeline-entry-wrapper::before {
      content: '';
      position: absolute;
      left: -10px;
      top: 0.9rem;
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #14b8a6;
      box-shadow: 0 0 0 6px rgba(20, 184, 166, 0.14);
      transform: translateX(-50%);
      z-index: 2;
    }
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 0rem;
      padding-left: 0.6rem;
    }
    .entry-left .entry-card,
    .entry-right .entry-card {
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
      max-width: 100%;
      margin: 0;
    }
    .entry-left .entry-image-wrap,
    .entry-right .entry-image-wrap {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      margin: 0;
    }
    .entry-img {
      width: 100%;
      max-width: 400px;
    }
    .annotation-right,
    .annotation-left {
      padding-left: 30px;
      padding-right: 0;
      align-items: flex-start;
      text-align: left;
    }


  }
</style>

<script>
  /* ─────────────────────────────────────────────────────────────
   *  Timeline: dynamic serpentine SVG connector
   *  Strategy:
   *    1. After DOM renders, measure each .timeline-entry-wrapper
   *    2. Compute an anchor point per entry (near the image corner)
   *    3. Build a cubic-bezier path through those points
   *    4. Place each dot group at its anchor
   *    5. Use IntersectionObserver to trigger the draw animation
   * ─────────────────────────────────────────────────────────────*/

  const DASH = 11;   // visible dash length (px)
  const GAP  = 8;    // visible gap length (px)

  /**
   * Build a path d-string connecting the points using the geometric pattern from code.html.
   * pts array has 2 points per card: [entry0, exit0, entry1, exit1, entry2, exit2, ...]
   * We ONLY draw paths connecting an exit point to the NEXT entry point.
   * This leaves a gap over the card itself, creating the illusion that the line goes behind it.
   */
  /** Layout Y inside timeline — not affected by reveal transforms on children. */
  function offsetTopIn(container: HTMLElement, el: HTMLElement): number {
    let top = 0;
    let node: HTMLElement | null = el;
    while (node && node !== container) {
      top += node.offsetTop;
      node = node.offsetParent as HTMLElement | null;
    }
    return top;
  }

  function buildPathD(pts: { x: number; y: number }[], containerW: number): string {
    if (pts.length < 4) return '';
    let d = '';

    // Loop through the gaps between cards
    for (let i = 1; i < pts.length - 1; i += 2) {
      const exitPt = pts[i];
      const entryPt = pts[i + 1];

      const yMid = exitPt.y + (entryPt.y - exitPt.y) / 2;
      
      // Calculate a safe curve radius
      const maxR = Math.min(
        50, 
        Math.abs(entryPt.y - exitPt.y) / 2, 
        Math.abs(entryPt.x - exitPt.x) / 2
      );
      const r = Math.max(1, maxR); // Ensure non-zero
      
      const dirX = exitPt.x < entryPt.x ? 1 : -1;

      // Move to the exit point of the current card
      d += `M ${exitPt.x} ${exitPt.y} `;
      
      // Draw straight line down to the curve start
      d += `L ${exitPt.x} ${yMid - r} `;
      // Draw curve to horizontal
      d += `Q ${exitPt.x} ${yMid} ${exitPt.x + r * dirX} ${yMid} `;
      // Draw straight line across
      d += `L ${entryPt.x - r * dirX} ${yMid} `;
      // Draw curve to vertical down
      d += `Q ${entryPt.x} ${yMid} ${entryPt.x} ${yMid + r} `;
      // Draw straight line down to the entry point of the next card
      d += `L ${entryPt.x} ${entryPt.y} `;
    }
    
    return d;
  }

  function buildTimeline() {
    const timeline  = document.getElementById('exp-timeline');
    const svg       = document.getElementById('timeline-path-svg') as SVGSVGElement | null;
    const mainPath  = document.getElementById('timeline-main-path') as SVGPathElement | null;
    const dotGroups = document.querySelectorAll<SVGGElement>('.path-dot-group');
    const entries   = document.querySelectorAll<HTMLElement>('.timeline-entry-wrapper');

    if (!timeline || !svg || !mainPath || !entries.length) return;

    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    if (isMobile) {
      mainPath.setAttribute('d', '');
      dotGroups.forEach((g) => {
        g.style.display = 'none';
      });
      return;
    }

    /* ── 1. Size the SVG to match the live container ── */
    const containerRect = timeline.getBoundingClientRect();
    const W = containerRect.width;
    const H = containerRect.height;
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.setAttribute('width',  `${W}`);
    svg.setAttribute('height', `${H}`);

    /* ── 2. Measure anchor for each entry ── */
    const pts: { x: number; y: number }[] = [];

    entries.forEach((entry) => {
      const innerEl =
        entry.querySelector<HTMLElement>('.timeline-entry') ??
        entry;

      // En móvil el dot debe "caer" sobre la foto, no sobre el alto total de la fila.
      const anchorEl = isMobile
        ? (entry.querySelector<HTMLElement>('.entry-image-wrap') ?? innerEl)
        : innerEl;

      const side    = entry.dataset.side;

      // Alinea el dot con la línea lateral (mismo left que `timeline::before`).
      const x = isMobile ? 16 : (side === 'left' ? W * 0.77 : W * 0.23);

      const verticalGap = 30;
      const rowTop      = offsetTopIn(timeline, anchorEl);
      const yTop        = rowTop - verticalGap;
      const yBottom     = rowTop + anchorEl.offsetHeight + verticalGap;

      pts.push({ x, y: yTop });
      pts.push({ x, y: yBottom });
    });

    /* ── 3. Build and set path ── */
    const d = buildPathD(pts, W);
    mainPath.setAttribute('d', d);

    /* ── 4. Position dots ── */
    dotGroups.forEach((g) => {
      const idx = parseInt(g.dataset.index ?? '0', 10);
      const pt  = pts[idx];
      if (!pt) return;

      g.style.display = '';
      g.setAttribute('transform', `translate(${pt.x}, ${pt.y})`);
    });
  }

  let _rebuildTimer: ReturnType<typeof setTimeout>;
  function scheduleBuildTimeline() {
    clearTimeout(_rebuildTimer);
    _rebuildTimer = setTimeout(() => requestAnimationFrame(buildTimeline), 50);
  }

  let _timelineInitialized = false;

  function initTimeline() {
    const timeline = document.getElementById('exp-timeline');
    const entries = document.querySelectorAll<HTMLElement>('.timeline-entry-wrapper');
    if (!timeline || !entries.length) return;

    entries.forEach((el) => el.classList.add('js-reveal'));

    const cardObserver = new IntersectionObserver(
      (obs) => {
        obs.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            cardObserver.unobserve(e.target);
            scheduleBuildTimeline();
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
    );
    entries.forEach((el) => cardObserver.observe(el));

    timeline.querySelectorAll<HTMLImageElement>('.entry-img').forEach((img) => {
      if (!img.complete) {
        img.addEventListener('load', scheduleBuildTimeline, { once: true });
      }
    });

    if (!_timelineInitialized) {
      _timelineInitialized = true;
      window.addEventListener('resize', scheduleBuildTimeline);
      new ResizeObserver(scheduleBuildTimeline).observe(timeline);
    }

    requestAnimationFrame(() => requestAnimationFrame(buildTimeline));
  }

  document.addEventListener('astro:page-load', () => {
    _timelineInitialized = false;
    initTimeline();
  });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTimeline);
  } else {
    initTimeline();
  }
</script>
