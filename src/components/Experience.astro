---
// Timeline entries — matching the design layout
const TIMELINE = [
    {
    period: 'Diciembre 2024 · Marzo 2026',
    role: 'Desarrollador Full-stack',
    company: 'Kiwi Company',
    companyLogo: '/kiwi-bird.webp',
    companyColor: '#22c55e',
    isPresent: true,
    description:
      'CRM integral para dealer de autos enfocado en la gestión de ventas e inventario vehicular. Módulos clave y logros:<br/>• Llamadas telefónicas integradas directamente en la web y sockets en tiempo real con Twilio SMS.<br/>• Desarrollé <strong>vistas configurables y tablas inteligentes</strong> que dieron autonomía a los usuarios finales para gestionar sus propios datos.<br/>• Logré que equipos comerciales generen <strong>reportes claros en segundos</strong>.<br/>• Mejoré la usabilidad de una plataforma crítica para concesionarios, <strong>mejorando la adopción y eficiencia del sistema</strong>.',
    tags: ['Next.js', 'React', 'Express.js', 'WebSocket', 'PostgreSQL'],
    image: '/projects/flowsups-3.webp',
    side: 'left' as const,
    annotation: { text: 'Actualmente en', highlight: 'Kiwi Company' },
  },
  {
    period: 'Abril 2024 · Noviembre 2024',
    role: 'Desarrollador Full-stack',
    company: 'Kiwi Company',
    companyLogo: '/kiwi-bird.webp',
    companyColor: '#22c55e',
    isPresent: true,
    description:
      'Lideré la arquitectura y desarrollo de Social Store (cliente externo), un <strong>sistema multi-tenant de tiendas online</strong> con dashboards para vendedores, autenticación 2FA e integraciones de pago. Desarrollé un <strong>sistema editor de plantillas</strong> que incluye: <br/>• Personalización interactiva de layouts, textos, fuentes y colores.<br/>• Gestión de imágenes (subida propia o galería).<br/>• Control de versiones para diseños.',
    tags: ['Next.js', 'Node.js', 'NestJS', 'React', 'Docker', 'Pasarela de pagos'],
    image: '/projects/social-s-1.webp',
    side: 'right' as const,
    annotation: { text: 'Actualmente en', highlight: 'Kiwi Company' },
  },
  {
    period: '2024',
    role: 'Desarrollo Web & E-commerce',
    company: 'Kiwi Company',
    companyLogo: '/kiwi-bird.webp',
    companyColor: '#22c55e',
    description:
      '<strong>Web Corporativa & CMS:</strong> Integré Strapi para gestión de contenidos dinámicos. Creé secciones de blog y portafolio con internacionalización.<br/><br/><strong>E-commerce Shopify:</strong> Implementé tiendas con código personalizado usando Liquid, JavaScript y CSS, optimizando el flujo de compra de varios clientes.',
    tags: ['Strapi', 'Next.js', 'Shopify', 'Liquid', 'JavaScript', 'CSS', 'i18n'],
    image: '/projects/kiwi-company.webp',
    side: 'left' as const,
    annotation: { text: 'Múltiples proyectos', highlight: 'en paralelo' },
  },
  {
    period: 'Enero 2023 · Octubre 2023',
    role: 'Desarrollador Full-stack',
    company: 'Incubadora Desafío Latam',
    companyLogo: '/desafiolatam_logo.jpeg',
    companyColor: '#6366f1',
    description:
      'Desarrollé InnovaXD: plataforma web de noticias para escolares con <strong>inteligencia artificial</strong> (GPT OpenAI). Proyecto presentado en el Summit de Fundación País Digital, con clientes como Diario El Mercurio, Fundación Kodea y el Ministerio de Educación en Chile.',
    tags: ['React', 'Node.js', 'OpenAI', 'MongoDB', 'Express'],
    image: '/projects/pantalla-innova.jpg',
    link: 'https://innovaxd.cl/',
    side: 'right' as const,
    annotation: { text: 'Aquí comenzó', highlight: 'todo' },
  },
];
---

<section class="exp-section">
  <!-- Section Header -->
  <div class="exp-header">
    <span class="exp-label">● EXPERIENCIA</span>
    <h2 class="exp-title">
      Mi <em>trayectoria</em> profesional
    </h2>
    <!-- Sparkle decoration -->
    <div class="header-sparkle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#f43f5e" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
      </svg>
    </div>
    <p class="exp-subtitle">
      Más de 3 años construyendo soluciones web escalables,<br />
      colaborando con equipos y generando impacto real.
    </p>
  </div>

  <!-- Zigzag Timeline -->
  <div class="timeline" id="exp-timeline">

    <!-- ═══ Serpentine SVG connector — positions set by JS ═══ -->
    <svg
      class="timeline-svg"
      id="timeline-path-svg"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="lineGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%"   stop-color="#b52330" stop-opacity="0.75" />
          <stop offset="50%"  stop-color="#e86a77" stop-opacity="0.55" />
          <stop offset="100%" stop-color="#006a62" stop-opacity="0.65" />
        </linearGradient>
      </defs>

      <!--
      <!-- Dashed visible path -->
      <path
        id="timeline-main-path"
        stroke="url(#lineGrad)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="8 8"
        fill="none"
        class="main-path"
      />

      <!-- Dot groups — JS positions them via cx/cy after measuring DOM -->
      {TIMELINE.flatMap((_, i) => {
        const color = i % 2 === 0 ? '#ff5a5f' : 'teal';
        const dots = [];
        
        // Dot at entry point of the card (except for the very first card)
        if (i > 0) {
          dots.push(
            <g class="path-dot-group" data-index={i * 2} data-fill={color}>
              <circle class="path-dot-ring" r="17" fill={color} fill-opacity="0.16" />
              <circle class="path-dot"      r="9"  fill={color} />
            </g>
          );
        }
        
        // Dot at exit point of the card (except for the very last card)
        if (i < TIMELINE.length - 1) {
          dots.push(
            <g class="path-dot-group" data-index={i * 2 + 1} data-fill={color}>
              <circle class="path-dot-ring" r="17" fill={color} fill-opacity="0.16" />
              <circle class="path-dot"      r="9"  fill={color} />
            </g>
          );
        }
        
        return dots;
      })}
    </svg>
    <!-- ══════════════════════════════════════════════════════ -->
    {TIMELINE.map((item, i) => {
      const isLeft = item.side === 'left';
      return (
        <div class="timeline-entry-wrapper" data-index={i} data-side={item.side}>
          {/* The entry row */}
          <div class={`timeline-entry entry-${item.side}`} data-side={item.side}>
            {/* Content card */}
            <div class="entry-card">
              <span class="entry-period">{item.period}</span>
              <h3 class="entry-role text-slate-700">{item.role}</h3>
              <div class="entry-company">
                <span class="company-logo">
                  {item.companyLogo.includes('/') ? (
                    <img src={item.companyLogo} alt={item.company} class="company-logo-img" />
                  ) : (
                    item.companyLogo
                  )}
                </span>
                <span class="company-name">{item.company}</span>
              </div>
              <p class="entry-desc" set:html={item.description}></p>
              <div class="entry-tags">
                {item.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              {item.link && (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="entry-link">
                  Ver proyecto →
                </a>
              )}
            </div>

            {/* Image with glow */}
            <div class="entry-image-wrap">
              <div class="image-glow"></div>
              <img src={item.image} alt={`${item.role} en ${item.company}`} class="entry-img" loading="lazy" />
            </div>
          </div>

          {/* Annotation - positioned below the entry (Disabled for now) */}
         
            <div class={`annotation ${isLeft ? 'annotation-right' : 'annotation-left'}`}>
              {false && item.annotation && (
              <svg class="annotation-arrow" viewBox="0 0 60 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                {isLeft ? (
                                    <Fragment>
                    <path d="M10 5 Q40 5 45 25 Q50 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M36 34 L30 40 L38 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>
                ) : (
                  <Fragment>
                    <path d="M50 5 Q20 5 15 25 Q10 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M24 34 L30 40 L22 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>

                )}
              </svg>
              <p class="annotation-text">
                {item.annotation.text}<br/>
                <span class="annotation-highlight">{item.annotation.highlight}</span>
              </p>
            )}
            </div>
          
        </div>
      );
    })}
  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────────── */
  .exp-section {
    position: relative;
    padding: 4rem 0 6rem;
    overflow: hidden;
  }

  /* Decorative blobs */
  .exp-section::before,
  .exp-section::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .exp-section::before {
    width: 380px; height: 380px;
    background: #fdd0d8;
    top: -80px; left: -100px;
    opacity: 0.4;
  }
  .exp-section::after {
    width: 320px; height: 320px;
    background: #b0ede8;
    bottom: 60px; right: -80px;
    opacity: 0.3;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .exp-header {
    text-align: center;
    margin-bottom: 5rem;
    position: relative;
    z-index: 1;
  }
  .exp-label {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #006a62;
    margin-bottom: 0.8rem;
  }
  .exp-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #261817;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .exp-title em {
    font-style: normal;
    font-family: 'Newsreader', serif;
    color: var(--primary);
  }
  .header-sparkle {
    position: absolute;
    top: 55%;
    left: 18%;
    opacity: 0.45;
    animation: float-sparkle 4s ease-in-out infinite;
  }
  @keyframes float-sparkle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(15deg); }
  }
  .exp-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    color: #484848;
    line-height: 1.6;
  }

  /* ── Timeline container ────────────────────────────────────── */
  .timeline {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    z-index: 1;
  }

  /* ── Serpentine SVG line ────────────────────────────────────── */
  .timeline-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  /*
   * The dashed path is always fully visible.
   */
  .main-path {
    opacity: 1;
  }

  /* Accent dots — hidden, pop in with spring scale */
  .path-dot,
  .path-dot-ring {
    transform-origin: center;
  }

  /* Pulsing ring on each dot - removed animation */
  .path-dot-ring {
    opacity: 0.16;
  }

  /* ── Entry wrapper ────────────────────────────────────────── */
  .timeline-entry-wrapper {
    position: relative;
    margin-bottom: 12rem;
  }
  .timeline-entry-wrapper:last-child {
    margin-bottom: 0;
  }

  /* ── Each entry ────────────────────────────────────────────── */
  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    position: relative;
  }

  /* Left: card | image */
  .entry-left .entry-card {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }
  .entry-left .entry-image-wrap {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }

  /* Right: image | card */
  .entry-right .entry-card {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }
  .entry-right .entry-image-wrap {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }

  /* ── Content Area ──────────────────────────────────────────── */
  .entry-card {
    transition: transform 0.35s ease;
    max-width: 440px;
    position: relative;
  }
  .entry-card:hover {
    transform: translateY(-4px);
  }

  .entry-period {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--primary);
    display: block;
    margin-bottom: 0.45rem;
  }
  .entry-role {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: #261817;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }
  .entry-company {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .company-logo {
    font-size: 1rem;
    line-height: 1;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7f7f7;
