---
// Timeline entries — matching the design layout
const TIMELINE = [
  {
    period: 'Abril 2024 · Actualidad',
    role: 'Desarrollador Full-stack Senior',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    isPresent: true,
    description:
      'Lideré la arquitectura y desarrollo de Social Store: un sistema multi-tenant de tiendas en línea con autenticación 2FA, dashboards para vendedores, integración de Mercado Pago y PayPal, y un editor de plantillas con preview interactivo.',
    tags: ['Next.js', 'Node.js', 'NestJS', 'React', 'Strapi', 'Docker'],
    image: '/projects/social-s-1.webp',
    side: 'left' as const,
    annotation: { text: 'Actualmente en', highlight: 'Kiwi Company' },
  },
  {
    period: '2024',
    role: 'Web Corporativa & CMS',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    description:
      'Integré Strapi como CMS para gestión de contenidos dinámicos. Creé secciones de blog y portafolio conectadas al backend. Implementé tema oscuro/claro e internacionalización en español/inglés.',
    tags: ['Strapi', 'Next.js', 'CSS', 'i18n'],
    image: '/projects/social-s-1.webp',
    side: 'right' as const,
    annotation: { text: 'Creciendo y generando', highlight: 'impacto en equipo' },
  },
  {
    period: '2024',
    role: 'E-commerce Shopify',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    description:
      'Implementé tiendas en Shopify con código personalizado usando Liquid, JavaScript y CSS. Optimicé el flujo de compra y la experiencia de usuario de varios clientes.',
    tags: ['Shopify', 'Liquid', 'JavaScript', 'CSS'],
    image: '/projects/social-s-1.webp',
    side: 'left' as const,
    annotation: { text: 'Mis primeros proyectos', highlight: 'como freelancer' },
  },
  {
    period: 'Enero 2023 · Octubre 2023',
    role: 'Desarrollador Full-stack',
    company: 'Incubadora Desafío Latam',
    companyLogo: '🚀',
    companyColor: '#6366f1',
    description:
      'Desarrollé InnovaXD: plataforma web de noticias para escolares con inteligencia artificial (GPT OpenAI). Proyecto presentado en el Summit de Fundación País Digital, con clientes como Microsoft, Diario El Mercurio, Fundación Kodea y el Ministerio de Educación.',
    tags: ['React', 'Node.js', 'OpenAI', 'MongoDB', 'Express'],
    image: '/projects/pantalla-innova.jpg',
    link: 'https://innovaxd.cl/',
    side: 'right' as const,
    annotation: { text: 'Aquí comenzó', highlight: 'todo' },
  },
];
---

<section class="exp-section">
  <!-- Section Header -->
  <div class="exp-header">
    <span class="exp-label">● EXPERIENCIA</span>
    <h2 class="exp-title">
      Mi <em>trayectoria</em> profesional
    </h2>
    <!-- Sparkle decoration -->
    <div class="header-sparkle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#f43f5e" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
      </svg>
    </div>
    <p class="exp-subtitle">
      Más de 3 años construyendo soluciones web escalables,<br />
      colaborando con equipos y generando impacto real.
    </p>
  </div>

  <!-- Zigzag Timeline -->
  <div class="timeline" id="exp-timeline">
    {TIMELINE.map((item, i) => {
      const isLeft = item.side === 'left';
      
      return (
        <div class="timeline-entry-wrapper" data-index={i} data-side={item.side}>
          {/* The entry row */}
          <div class={`timeline-entry entry-${item.side}`} data-side={item.side}>
            {/* Content card */}
            <div class="entry-card">
              <span class="entry-period">{item.period}</span>
              <h3 class="entry-role">{item.role}</h3>
              <div class="entry-company">
                <span class="company-logo">{item.companyLogo}</span>
                <span class="company-name">{item.company}</span>
              </div>
              <p class="entry-desc">{item.description}</p>
              <div class="entry-tags">
                {item.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              {item.link && (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="entry-link">
                  Ver proyecto →
                </a>
              )}
            </div>

            {/* Image with glow */}
            <div class="entry-image-wrap">
              <div class="image-glow"></div>
              <img src={item.image} alt={`${item.role} en ${item.company}`} class="entry-img" loading="lazy" />
            </div>
          </div>

          {/* Annotation - positioned below the entry */}
          {item.annotation && (
            <div class={`annotation ${isLeft ? 'annotation-right' : 'annotation-left'}`}>
              <svg class="annotation-arrow" viewBox="0 0 60 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                {isLeft ? (
                  <Fragment>
                    <path d="M50 5 Q20 5 15 25 Q10 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M24 34 L30 40 L22 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>
                ) : (
                  <Fragment>
                    <path d="M10 5 Q40 5 45 25 Q50 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M36 34 L30 40 L38 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>
                )}
              </svg>
              <p class="annotation-text">
                {item.annotation.text}{' '}
                <span class="annotation-highlight">{item.annotation.highlight}</span>
              </p>
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────────── */
  .exp-section {
    position: relative;
    padding: 4rem 0 6rem;
    overflow: hidden;
  }

  /* Decorative blobs */
  .exp-section::before,
  .exp-section::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .exp-section::before {
    width: 380px; height: 380px;
    background: #fdd0d8;
    top: -80px; left: -100px;
    opacity: 0.4;
  }
  .exp-section::after {
    width: 320px; height: 320px;
    background: #b0ede8;
    bottom: 60px; right: -80px;
    opacity: 0.3;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .exp-header {
    text-align: center;
    margin-bottom: 5rem;
    position: relative;
    z-index: 1;
  }
  .exp-label {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #006a62;
    margin-bottom: 0.8rem;
  }
  .exp-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #261817;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .exp-title em {
    font-style: italic;
    font-family: 'Newsreader', serif;
    color: #b52330;
  }
  .header-sparkle {
    position: absolute;
    top: 55%;
    left: 18%;
    opacity: 0.45;
    animation: float-sparkle 4s ease-in-out infinite;
  }
  @keyframes float-sparkle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(15deg); }
  }
  .exp-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    color: #484848;
    line-height: 1.6;
  }

  /* ── Timeline container ────────────────────────────────────── */
  .timeline {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    z-index: 1;
  }

  /* ── Entry wrapper ────────────────────────────────────────── */
  .timeline-entry-wrapper {
    position: relative;
  }

  /* ── Each entry ────────────────────────────────────────────── */
  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    position: relative;
    margin-bottom: 4rem;
  }

  /* Left: card | image */
  .entry-left .entry-card {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }
  .entry-left .entry-image-wrap {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }

  /* Right: image | card */
  .entry-right .entry-card {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }
  .entry-right .entry-image-wrap {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }

  /* ── Content Area ──────────────────────────────────────────── */
  .entry-card {
    transition: transform 0.35s ease;
    max-width: 440px;
    position: relative;
  }
  .entry-card:hover {
    transform: translateY(-4px);
  }

  .entry-period {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #b52330;
    display: block;
    margin-bottom: 0.45rem;
  }
  .entry-role {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: #261817;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }
  .entry-company {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .company-logo {
    font-size: 1rem;
    line-height: 1;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7f7f7;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  .company-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    color: #484848;
  }
  .entry-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    color: #5a5a5a;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #b52330;
    background: #fff5f6;
    border: 1px solid #fdd0d8;
    border-radius: 999px;
    padding: 0.22rem 0.7rem;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .tag:hover {
    background: #fdd0d8;
    color: #8a1a28;
    transform: translateY(-1px);
  }
  .entry-link {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #006a62;
    text-decoration: none;
    transition: color 0.2s;
    margin-top: 0.25rem;
  }
  .entry-link:hover {
    color: #b52330;
  }

  /* ── Image column ──────────────────────────────────────────── */
  .entry-image-wrap {
    position: relative;
    width: fit-content;
  }
  .image-glow {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(127, 230, 220, 0.2) 0%, transparent 70%);
    filter: blur(25px);
    z-index: 0;
    pointer-events: none;
  }
  .entry-img {
    width: 380px;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    display: block;
    position: relative;
    z-index: 1;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .timeline-entry:hover .entry-img {
    transform: scale(1.03);
    box-shadow: 0 16px 48px rgba(0,0,0,0.15);
  }

  /* ── Annotation ────────────────────────────────────────────── */
  .annotation {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    pointer-events: none;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  .annotation-right {
    align-items: flex-end;
    text-align: right;
    /* Position below the image */
    padding-left: 50%;
    padding-right: 0;
  }
  .annotation-left {
    align-items: flex-start;
    text-align: left;
    /* Position below the image */
    padding-right: 50%;
    padding-left: 0;
  }

  .annotation-arrow {
    width: 50px;
    height: 42px;
  }
  .annotation-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.78rem;
    font-style: italic;
    color: #777;
    line-height: 1.4;
  }
  .annotation-highlight {
    color: #b52330;
    font-weight: 700;
    font-style: italic;
  }



  /* ── Scroll-reveal animations ──────────────────────────────── */
  .timeline-entry-wrapper.js-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-entry-wrapper.is-visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .timeline::before {
      content: '';
      position: absolute;
      left: 15px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: repeating-linear-gradient(
        to bottom,
        #e2bebc 0px,
        #e2bebc 6px,
        transparent 6px,
        transparent 14px
      );
      z-index: 0;
    }
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .entry-left .entry-card,
    .entry-right .entry-card {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      max-width: 100%;
      margin: 0;
    }
    .entry-left .entry-image-wrap,
    .entry-right .entry-image-wrap {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      margin: 0;
    }
    .entry-img {
      width: 100%;
      max-width: 400px;
    }
    .annotation-right,
    .annotation-left {
      padding-left: 30px;
      padding-right: 0;
      align-items: flex-start;
      text-align: left;
    }


  }
</style>

<script>
  function initTimeline() {
    const entries = document.querySelectorAll('.timeline-entry-wrapper');
    if (!entries.length) return;

    // Add hidden class via JS so content is visible without JS
    entries.forEach((el) => el.classList.add('js-reveal'));

    const observer = new IntersectionObserver(
      (obs) => {
        obs.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
    );

    entries.forEach((el) => observer.observe(el));
  }

  // Works with or without Astro View Transitions
  document.addEventListener('astro:page-load', initTimeline);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTimeline);
  } else {
    initTimeline();
  }
</script>
