    height: 100%;
    object-fit: contain;
    padding: 0.2rem;
  }
  .company-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    /* color: #484848; */
    color: #334155;
  }
  .entry-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
