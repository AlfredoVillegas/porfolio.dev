---
// Timeline entries — matching the design layout
const TIMELINE = [
    {
    period: 'Abril 2024 · Actualidad',
    role: 'Desarrollador Full-stack',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    isPresent: true,
    description:
      'CRM integral para dealer de autos con gestión de ventas, seguimiento de clientes y control de inventario vehicular.',
    tags: ['Next.js', 'React', 'Node.js', 'PostgreSQL', 'Express.js', 'WebSocket'],
    image: '/projects/flowsups.webp',
    side: 'left' as const,
    annotation: { text: 'Actualmente en', highlight: 'Kiwi Company' },
  },
  {
    period: 'Abril 2024 · Actualidad',
    role: 'Desarrollador Full-stack Senior',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    isPresent: true,
    description:
      'Lideré la arquitectura y desarrollo de Social Store: un sistema multi-tenant de tiendas en línea con autenticación 2FA, dashboards para vendedores, integración de Mercado Pago y PayPal, y un editor de plantillas con preview interactivo.',
    tags: ['Next.js', 'Node.js', 'NestJS', 'React', 'Strapi', 'Docker'],
    image: '/projects/social-s-1.webp',
    side: 'left' as const,
    annotation: { text: 'Actualmente en', highlight: 'Kiwi Company' },
  },
  {
    period: '2024',
    role: 'Web Corporativa & CMS',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    description:
      'Integré Strapi como CMS para gestión de contenidos dinámicos. Creé secciones de blog y portafolio conectadas al backend. Implementé tema oscuro/claro e internacionalización en español/inglés.',
    tags: ['Strapi', 'Next.js', 'CSS', 'i18n'],
    image: '/projects/social-s-1.webp',
    side: 'right' as const,
    annotation: { text: 'Creciendo y generando', highlight: 'impacto en equipo' },
  },
  {
    period: '2024',
    role: 'E-commerce Shopify',
    company: 'Kiwi Company',
    companyLogo: '🥝',
    companyColor: '#22c55e',
    description:
      'Implementé tiendas en Shopify con código personalizado usando Liquid, JavaScript y CSS. Optimicé el flujo de compra y la experiencia de usuario de varios clientes.',
    tags: ['Shopify', 'Liquid', 'JavaScript', 'CSS'],
    image: '/projects/social-s-1.webp',
    side: 'left' as const,
    annotation: { text: 'Mis primeros proyectos', highlight: 'como freelancer' },
  },
  {
    period: 'Enero 2023 · Octubre 2023',
    role: 'Desarrollador Full-stack',
    company: 'Incubadora Desafío Latam',
    companyLogo: '🚀',
    companyColor: '#6366f1',
    description:
      'Desarrollé InnovaXD: plataforma web de noticias para escolares con inteligencia artificial (GPT OpenAI). Proyecto presentado en el Summit de Fundación País Digital, con clientes como Microsoft, Diario El Mercurio, Fundación Kodea y el Ministerio de Educación.',
    tags: ['React', 'Node.js', 'OpenAI', 'MongoDB', 'Express'],
    image: '/projects/pantalla-innova.jpg',
    link: 'https://innovaxd.cl/',
    side: 'right' as const,
    annotation: { text: 'Aquí comenzó', highlight: 'todo' },
  },
];
---

<section class="exp-section">
  <!-- Section Header -->
  <div class="exp-header">
    <span class="exp-label">● EXPERIENCIA</span>
    <h2 class="exp-title">
      Mi <em>trayectoria</em> profesional
    </h2>
    <!-- Sparkle decoration -->
    <div class="header-sparkle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#f43f5e" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
      </svg>
    </div>
    <p class="exp-subtitle">
      Más de 3 años construyendo soluciones web escalables,<br />
      colaborando con equipos y generando impacto real.
    </p>
  </div>

  <!-- Zigzag Timeline -->
  <div class="timeline" id="exp-timeline">

    <!-- ═══ Serpentine SVG connector — positions set by JS ═══ -->
    <svg
      class="timeline-svg"
      id="timeline-path-svg"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="lineGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%"   stop-color="#b52330" stop-opacity="0.75" />
          <stop offset="50%"  stop-color="#e86a77" stop-opacity="0.55" />
          <stop offset="100%" stop-color="#006a62" stop-opacity="0.65" />
        </linearGradient>
      </defs>

      <!--
      <!-- Dashed visible path -->
      <path
        id="timeline-main-path"
        stroke="url(#lineGrad)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="8 8"
        fill="none"
        class="main-path"
      />

      <!-- Dot groups — JS positions them via cx/cy after measuring DOM -->
      {TIMELINE.flatMap((_, i) => {
        // Alternating colors based on index: even (left side) = red, odd (right side) = teal
        const color = i % 2 === 0 ? '#ff5a5f' : 'teal';
        return [
          <g class="path-dot-group" data-index={i * 2} data-fill={color}>
            <circle class="path-dot-ring" r="17" fill={color} fill-opacity="0.16" />
            <circle class="path-dot"      r="9"  fill={color} />
          </g>,
          <g class="path-dot-group" data-index={i * 2 + 1} data-fill={color}>
            <circle class="path-dot-ring" r="17" fill={color} fill-opacity="0.16" />
            <circle class="path-dot"      r="9"  fill={color} />
          </g>
        ];
      })}
    </svg>
    <!-- ══════════════════════════════════════════════════════ -->
    {TIMELINE.map((item, i) => {
      const isLeft = item.side === 'left';
      
      return (
        <div class="timeline-entry-wrapper" data-index={i} data-side={item.side}>
          {/* The entry row */}
          <div class={`timeline-entry entry-${item.side}`} data-side={item.side}>
            {/* Content card */}
            <div class="entry-card">
              <span class="entry-period">{item.period}</span>
              <h3 class="entry-role">{item.role}</h3>
              <div class="entry-company">
                <span class="company-logo">{item.companyLogo}</span>
                <span class="company-name">{item.company}</span>
              </div>
              <p class="entry-desc">{item.description}</p>
              <div class="entry-tags">
                {item.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              {item.link && (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="entry-link">
                  Ver proyecto →
                </a>
              )}
            </div>

            {/* Image with glow */}
            <div class="entry-image-wrap">
              <div class="image-glow"></div>
              <img src={item.image} alt={`${item.role} en ${item.company}`} class="entry-img" loading="lazy" />
            </div>
          </div>

          {/* Annotation - positioned below the entry */}
          {item.annotation && (
            <div class={`annotation ${isLeft ? 'annotation-right' : 'annotation-left'}`}>
              <svg class="annotation-arrow" viewBox="0 0 60 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                {isLeft ? (
                  <Fragment>
                    <path d="M50 5 Q20 5 15 25 Q10 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M24 34 L30 40 L22 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>
                ) : (
                  <Fragment>
                    <path d="M10 5 Q40 5 45 25 Q50 45 30 40" stroke="#b52330" stroke-width="1.4" stroke-dasharray="4 3" fill="none" />
                    <path d="M36 34 L30 40 L38 42" stroke="#b52330" stroke-width="1.4" fill="none" stroke-linecap="round" />
                  </Fragment>
                )}
              </svg>
              <p class="annotation-text">
                {item.annotation.text}{' '}
                <span class="annotation-highlight">{item.annotation.highlight}</span>
              </p>
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────────── */
  .exp-section {
    position: relative;
    padding: 4rem 0 6rem;
    overflow: hidden;
  }

  /* Decorative blobs */
  .exp-section::before,
  .exp-section::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .exp-section::before {
    width: 380px; height: 380px;
    background: #fdd0d8;
    top: -80px; left: -100px;
    opacity: 0.4;
  }
  .exp-section::after {
    width: 320px; height: 320px;
    background: #b0ede8;
    bottom: 60px; right: -80px;
    opacity: 0.3;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .exp-header {
    text-align: center;
    margin-bottom: 5rem;
    position: relative;
    z-index: 1;
  }
  .exp-label {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #006a62;
    margin-bottom: 0.8rem;
  }
  .exp-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #261817;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .exp-title em {
    font-style: normal;
    font-family: 'Newsreader', serif;
    color: var(--primary);
  }
  .header-sparkle {
    position: absolute;
    top: 55%;
    left: 18%;
    opacity: 0.45;
    animation: float-sparkle 4s ease-in-out infinite;
  }
  @keyframes float-sparkle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(15deg); }
  }
  .exp-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    color: #484848;
    line-height: 1.6;
  }

  /* ── Timeline container ────────────────────────────────────── */
  .timeline {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    z-index: 1;
  }

  /* ── Serpentine SVG line ────────────────────────────────────── */
  .timeline-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  /*
   * The dashed path is always fully visible.
   */
  .main-path {
    opacity: 1;
  }

  /* Accent dots — hidden, pop in with spring scale */
  .path-dot,
  .path-dot-ring {
    transform-origin: center;
  }

  /* Pulsing ring on each dot - removed animation */
  .path-dot-ring {
    opacity: 0.16;
  }

  /* ── Entry wrapper ────────────────────────────────────────── */
  .timeline-entry-wrapper {
    position: relative;
  }

  /* ── Each entry ────────────────────────────────────────────── */
  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    position: relative;
    margin-bottom: 8rem;
  }
  .timeline-entry:last-child {
    margin-bottom: 0;
  }

  /* Left: card | image */
  .entry-left .entry-card {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }
  .entry-left .entry-image-wrap {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }

  /* Right: image | card */
  .entry-right .entry-card {
    grid-column: 2;
    grid-row: 1;
    justify-self: start;
  }
  .entry-right .entry-image-wrap {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }

  /* ── Content Area ──────────────────────────────────────────── */
  .entry-card {
    transition: transform 0.35s ease;
    max-width: 440px;
    position: relative;
  }
  .entry-card:hover {
    transform: translateY(-4px);
  }

  .entry-period {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--primary);
    display: block;
    margin-bottom: 0.45rem;
  }
  .entry-role {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: #261817;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }
  .entry-company {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .company-logo {
    font-size: 1rem;
    line-height: 1;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7f7f7;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  .company-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    color: #484848;
  }
  .entry-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    color: #5a5a5a;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary);
    background: #fff5f6;
    border: 1px solid #fdd0d8;
    border-radius: 999px;
    padding: 0.22rem 0.7rem;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .tag:hover {
    background: #fdd0d8;
    color: #8a1a28;
    transform: translateY(-1px);
  }
  .entry-link {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #006a62;
    text-decoration: none;
    transition: color 0.2s;
    margin-top: 0.25rem;
  }
  .entry-link:hover {
    color: var(--primary);
  }

  /* ── Image column ──────────────────────────────────────────── */
  .entry-image-wrap {
    position: relative;
    width: fit-content;
  }
  .image-glow {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(127, 230, 220, 0.2) 0%, transparent 70%);
    filter: blur(25px);
    z-index: 0;
    pointer-events: none;
  }
  .entry-img {
    width: 380px;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    display: block;
    position: relative;
    z-index: 1;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .timeline-entry:hover .entry-img {
    transform: scale(1.03);
    box-shadow: 0 16px 48px rgba(0,0,0,0.15);
  }

  /* ── Annotation ────────────────────────────────────────────── */
  .annotation {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    pointer-events: none;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  .annotation-right {
    align-items: flex-end;
    text-align: right;
    /* Position below the image */
    padding-left: 50%;
    padding-right: 0;
  }
  .annotation-left {
    align-items: flex-start;
    text-align: left;
    /* Position below the image */
    padding-right: 50%;
    padding-left: 0;
  }

  .annotation-arrow {
    width: 50px;
    height: 42px;
  }
  .annotation-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.78rem;
    font-style: italic;
    color: #777;
    line-height: 1.4;
  }
  .annotation-highlight {
    color: var(--primary);
    font-weight: 700;
    font-style: italic;
  }



  /* ── Scroll-reveal animations ──────────────────────────────── */
  .timeline-entry-wrapper.js-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-entry-wrapper.is-visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .timeline::before {
      content: '';
      position: absolute;
      left: 15px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: repeating-linear-gradient(
        to bottom,
        #e2bebc 0px,
        #e2bebc 6px,
        transparent 6px,
        transparent 14px
      );
      z-index: 0;
    }
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .entry-left .entry-card,
    .entry-right .entry-card {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      max-width: 100%;
      margin: 0;
    }
    .entry-left .entry-image-wrap,
    .entry-right .entry-image-wrap {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      margin: 0;
    }
    .entry-img {
      width: 100%;
      max-width: 400px;
    }
    .annotation-right,
    .annotation-left {
      padding-left: 30px;
      padding-right: 0;
      align-items: flex-start;
      text-align: left;
    }


  }
</style>

<script>
  /* ─────────────────────────────────────────────────────────────
   *  Timeline: dynamic serpentine SVG connector
   *  Strategy:
   *    1. After DOM renders, measure each .timeline-entry-wrapper
   *    2. Compute an anchor point per entry (near the image corner)
   *    3. Build a cubic-bezier path through those points
   *    4. Place each dot group at its anchor
   *    5. Use IntersectionObserver to trigger the draw animation
   * ─────────────────────────────────────────────────────────────*/

  const DASH = 11;   // visible dash length (px)
  const GAP  = 8;    // visible gap length (px)

  /**
   * Build a path d-string connecting the points using the geometric pattern from code.html.
   * pts array has 2 points per card: [entry0, exit0, entry1, exit1, entry2, exit2, ...]
   * We ONLY draw paths connecting an exit point to the NEXT entry point.
   * This leaves a gap over the card itself, creating the illusion that the line goes behind it.
   */
  function buildPathD(pts: { x: number; y: number }[], containerW: number): string {
    if (pts.length < 4) return '';
    let d = '';

    // Loop through the gaps between cards
    for (let i = 1; i < pts.length - 1; i += 2) {
      const exitPt = pts[i];
      const entryPt = pts[i + 1];

      const yMid = exitPt.y + (entryPt.y - exitPt.y) / 2;
      
      // Calculate a safe curve radius
      const maxR = Math.min(
        50, 
        Math.abs(entryPt.y - exitPt.y) / 2, 
        Math.abs(entryPt.x - exitPt.x) / 2
      );
      const r = Math.max(1, maxR); // Ensure non-zero
      
      const dirX = exitPt.x < entryPt.x ? 1 : -1;

      // Move to the exit point of the current card
      d += `M ${exitPt.x} ${exitPt.y} `;
      
      // Draw straight line down to the curve start
      d += `L ${exitPt.x} ${yMid - r} `;
      // Draw curve to horizontal
      d += `Q ${exitPt.x} ${yMid} ${exitPt.x + r * dirX} ${yMid} `;
      // Draw straight line across
      d += `L ${entryPt.x - r * dirX} ${yMid} `;
      // Draw curve to vertical down
      d += `Q ${entryPt.x} ${yMid} ${entryPt.x} ${yMid + r} `;
      // Draw straight line down to the entry point of the next card
      d += `L ${entryPt.x} ${entryPt.y} `;
    }
    
    return d;
  }

  function buildTimeline() {
    const timeline  = document.getElementById('exp-timeline');
    const svg       = document.getElementById('timeline-path-svg') as SVGSVGElement | null;
    const mainPath  = document.getElementById('timeline-main-path') as SVGPathElement | null;
    const dotGroups = document.querySelectorAll<SVGGElement>('.path-dot-group');
    const entries   = document.querySelectorAll<HTMLElement>('.timeline-entry-wrapper');

    if (!timeline || !svg || !mainPath || !entries.length) return;

    /* ── 1. Size the SVG to match the live container ── */
    const containerRect = timeline.getBoundingClientRect();
    const W = containerRect.width;
    const H = containerRect.height;
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.setAttribute('width',  `${W}`);
    svg.setAttribute('height', `${H}`);

    /* ── 2. Measure anchor for each entry ── */
    const pts: { x: number; y: number }[] = [];

    entries.forEach((entry, i) => {
      // Measure the actual card+image grid, not the wrapper that includes annotation
      const innerEl = entry.querySelector<HTMLElement>('.timeline-entry') ?? entry;
      const r       = innerEl.getBoundingClientRect();
      const side    = entry.dataset.side; // 'left' | 'right'

      // left entries → image is on the right → anchor on the right side
      // right entries → image is on the left → anchor on the left  side
      const x = side === 'left' ? W * 0.77 : W * 0.23;

      // Create TWO points for each entry: Entry point (top) and Exit point (bottom)
      // We add a vertical gap (e.g., 30px) so the dots don't touch the images
      const verticalGap = 30;
      const yTop    = r.top    - containerRect.top - verticalGap;
      const yBottom = r.bottom - containerRect.top + verticalGap;

      pts.push({ x, y: yTop });    // index i*2
      pts.push({ x, y: yBottom }); // index i*2 + 1
    });

    /* ── 3. Build and set path ── */
    const d = buildPathD(pts, W);
    mainPath.setAttribute('d', d);


    /* ── 4. Position dots ── */
    dotGroups.forEach((g) => {
      const idx = parseInt(g.dataset.index ?? '0', 10);
      const pt  = pts[idx];
      if (!pt) return;
      // Move the group: translate its children by setting a transform
      g.setAttribute('transform', `translate(${pt.x}, ${pt.y})`);
    });


  }

  function initTimeline() {
    const entries = document.querySelectorAll('.timeline-entry-wrapper');
    if (!entries.length) return;

    /* Card scroll-reveal */
    entries.forEach((el) => el.classList.add('js-reveal'));
    const cardObserver = new IntersectionObserver(
      (obs) => {
        obs.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            cardObserver.unobserve(e.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
    );
    entries.forEach((el) => cardObserver.observe(el));

    /* Build the SVG path after a short rAF so layout is complete */
    requestAnimationFrame(() => requestAnimationFrame(buildTimeline));
  }

  /* Rebuild on resize (debounced) */
  let _resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(_resizeTimer);
    _resizeTimer = setTimeout(buildTimeline, 150);
  });

  document.addEventListener('astro:page-load', initTimeline);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTimeline);
  } else {
    initTimeline();
  }
</script>
