---
import LinkedIn from './icons/LinkedIn.astro';
---

<section class="rec-section">
  <!-- Decorative connector from Experience timeline -->
  <div class="rec-connector">
    <svg width="2" height="80" viewBox="0 0 2 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="1" y1="0" x2="1" y2="80" stroke="#e2bebc" stroke-width="2" stroke-dasharray="6 8" />
    </svg>
  </div>

  <!-- Section label -->
  <div class="rec-header">
    <span class="rec-label">● RECOMENDACIONES</span>
    <h2 class="rec-title">
      Lo <em>que dicen</em> de mi trabajo
    </h2>
  </div>

  <div class="rec-container">
    <!-- Recommendation card 1 -->
    <div class="rec-card js-rec-reveal" id="linkedin-recommendation">
      <!-- Large decorative quote mark -->
      <div class="rec-quote-mark" aria-hidden="true">"</div>

      <!-- LinkedIn badge -->
      <a
        href="https://linkedin.com/in/alfredo-villegas-backend/"
        target="_blank"
        rel="noopener noreferrer"
        class="rec-linkedin-badge"
        aria-label="Ver en LinkedIn"
      >
        <LinkedIn class="rec-linkedin-icon" />
        <span class="rec-badge-text">LinkedIn</span>
      </a>

      <!-- Quote body -->
      <blockquote class="rec-quote">
        <p>
          Alfredo demuestra compromiso, profesionalismo y agilidad en cada una de sus tareas. Es un desarrollador con
          capacidad de liderazgo, aprendizaje continuo y resolución de conflictos. Excelente trabajando en equipo y con
          basto conocimiento y experiencia como Fullstack. <strong>Sin duda fue un factor de valor en el equipo</strong> y recomiendo el
          trabajo con Alfredo.
        </p>
      </blockquote>

      <!-- Author -->
      <div class="rec-author">
        <img
          src="/perfil-cata.jpg"
          alt="Foto de Cata Evans Amador"
          class="rec-avatar"
          loading="lazy"
        />
        <div class="rec-author-info">
          <span class="rec-author-name">Cata Evans Amador</span>
          <span class="rec-author-role">Coordinadora de Proyectos en Desafío Latam</span>
          <span class="rec-author-date">17 de Noviembre de 2023 · Supervisaba directamente a Alfredo</span>
        </div>
      </div>

      <!-- Decorative sparkle -->
      <div class="rec-sparkle" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#006a62" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
        </svg>
      </div>
    </div>

    <!-- Recommendation card 2 -->
    <div class="rec-card js-rec-reveal" id="linkedin-recommendation-2">
      <!-- Large decorative quote mark -->
      <div class="rec-quote-mark" aria-hidden="true">"</div>

      <!-- LinkedIn badge -->
      <a
        href="https://linkedin.com/in/alfredo-villegas-backend/"
        target="_blank"
        rel="noopener noreferrer"
        class="rec-linkedin-badge"
        aria-label="Ver en LinkedIn"
      >
        <LinkedIn class="rec-linkedin-icon" />
        <span class="rec-badge-text">LinkedIn</span>
      </a>

      <!-- Quote body -->
      <blockquote class="rec-quote">
        <p>
          Trabajé con Alfredo Villegas en Kiwi Company durante varios proyectos donde tuve la oportunidad de liderar la gestión del producto y la coordinación de los equipos. Puedo afirmar que <strong>es uno de los desarrolladores más completos con los que he colaborado</strong>.
        </p>
        <p>
          Combina una sólida capacidad técnica con una visión práctica del producto, lo que le permite comprender rápidamente los objetivos del negocio y convertirlos en soluciones eficientes y bien ejecutadas. Siempre destacó por su autonomía, responsabilidad y capacidad para enfrentar retos complejos manteniendo un alto nivel de calidad en sus entregables.
        </p>
        <!-- Hidden paragraphs -->
        <div class="rec-extra" aria-hidden="true">
          <p>
            Más allá de sus habilidades como desarrollador Full Stack, aporta criterio, proactividad y una actitud de colaboración que fortalece cualquier equipo. Es el tipo de profesional que no solo cumple con lo esperado, sino que constantemente busca mejorar el producto, los procesos y la experiencia del usuario final.
          </p>
          <p>
            Fue un verdadero placer trabajar con él y lo recomiendo plenamente para cualquier organización que busque talento técnico de alto nivel con mentalidad de producto y orientación a resultados.
          </p>
        </div>
      </blockquote>
      <!-- Toggle button -->
      <button class="rec-toggle" aria-expanded="false" aria-controls="jose-extra">
        <span class="rec-toggle-text">Ver más</span>
        <svg class="rec-toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>

      <!-- Author -->
      <div class="rec-author">
        <img
          src="/jose-goncalves.webp"
          alt="Foto de José Goncalves"
          class="rec-avatar"
          loading="lazy"
        />
        <div class="rec-author-info">
          <span class="rec-author-name">José Goncalves</span>
          <span class="rec-author-role">Product Owner / Project Manager en Kiwi Company</span>
          <span class="rec-author-date">8 de junio de 2026 · José supervisaba directamente a Alfredo</span>
        </div>
      </div>

      <!-- Decorative sparkle -->
      <div class="rec-sparkle" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#006a62" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────────── */
  .rec-section {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.5rem 6rem;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Connector line from timeline ────────────────────────── */
  .rec-connector {
    margin-bottom: 2rem;
    opacity: 0.6;
  }

  /* ── Container for multiple cards ────────────────────────── */
  .rec-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .rec-container {
      flex-direction: row;
      justify-content: center;
      align-items: flex-start;
      gap: 2.5rem;
    }
  }

  /* ── Header ──────────────────────────────────────────────── */
  .rec-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .rec-label {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #006a62;
    margin-bottom: 0.8rem;
  }
  .rec-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    color: #261817;
    line-height: 1.15;
  }
  .rec-title em {
    font-style: normal;
    font-family: 'Newsreader', serif;
    color: var(--primary);
  }

  /* ── Card ────────────────────────────────────────────────── */
  .rec-card {
    position: relative;
    max-width: 600px;
    width: 100%;
    padding: 3rem 3rem 2.5rem;
    background: #ffffff;
    border: 1px solid #e2bebc40;
    border-radius: 1.25rem;
    box-shadow:
      0 4px 24px rgba(181, 35, 48, 0.04),
      0 1px 4px rgba(0, 0, 0, 0.03);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    margin: 0 auto;
  }
  .rec-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(181, 35, 48, 0.08),
      0 2px 8px rgba(0, 0, 0, 0.04);
  }


  /* ── Quote mark ──────────────────────────────────────────── */
  .rec-quote-mark {
    font-family: 'Newsreader', serif;
    font-size: 5rem;
    line-height: 1;
    color: #b52330;
    opacity: 0.12;
    position: absolute;
    top: 0.75rem;
    left: 1.5rem;
    pointer-events: none;
    user-select: none;
  }

  /* ── LinkedIn badge ──────────────────────────────────────── */
  .rec-linkedin-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem 0.35rem 0.5rem;
    border-radius: 999px;
    background: #f0f7ff;
    border: 1px solid #d0e4f7;
    text-decoration: none;
    transition: background 0.25s, transform 0.25s;
  }
  .rec-linkedin-badge:hover {
    background: #dceefb;
    transform: scale(1.05);
  }
  .rec-linkedin-icon {
    width: 1rem;
    height: 1rem;
    color: #0A66C2;
  }
  .rec-badge-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    color: #0A66C2;
    letter-spacing: 0.03em;
  }

  /* ── Quote body ──────────────────────────────────────────── */
  .rec-quote {
    margin: 0;
    position: relative;
    z-index: 1;
  }
  .rec-quote p {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    color: #484848;
    line-height: 1.5;
    margin: 0;
  }
  .rec-quote p:not(:last-child) {
    margin-bottom: 1rem;
  }
  .rec-quote strong {
    color: #261817;
    font-weight: 700;
  }

  /* ── Author ──────────────────────────────────────────────── */
  .rec-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f0eded;
  }
  .rec-avatar {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #fdd0d8;
    flex-shrink: 0;
  }
  .rec-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .rec-author-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 800;
    color: #261817;
  }
  .rec-author-role {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #334155;
  }
  .rec-author-date {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.72rem;
    color: #999;
    margin-top: 0.1rem;
  }

  /* ── Expand / collapse extra paragraphs ─────────────────── */
  .rec-extra {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.35s ease;
  }
  .rec-extra.is-open {
    max-height: 400px;
    opacity: 1;
  }

  .rec-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.75rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #006a62;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .rec-toggle:hover {
    color: #b52330;
  }
  .rec-toggle-icon {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .rec-toggle[aria-expanded="true"] .rec-toggle-icon {
    transform: rotate(180deg);
  }

  /* ── Decorative sparkle ──────────────────────────────────── */
  .rec-sparkle {
    position: absolute;
    bottom: -0.5rem;
    right: 2rem;
    opacity: 0.35;
    animation: rec-float 5s ease-in-out infinite;
  }
  @keyframes rec-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-6px) rotate(12deg); }
  }

  /* ── Scroll-reveal ───────────────────────────────────────── */
  .js-rec-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .js-rec-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .rec-section {
      padding-bottom: 2.25rem;
    }
    .rec-card {
      padding: 2.25rem 1.5rem 2rem;
    }
    .rec-quote-mark {
      font-size: 3.5rem;
      top: 0.5rem;
      left: 1rem;
    }
    .rec-linkedin-badge {
      top: 0.75rem;
      right: 0.75rem;
      padding: 0.3rem 0.6rem 0.3rem 0.4rem;
    }
    .rec-quote p {
      font-size: 0.9rem;
      line-height: 1.7;
    }
    .rec-author {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>

<script>
  function initRecReveal() {
    const cards = document.querySelectorAll('.js-rec-reveal');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card) => {
      observer.observe(card);
    });
  }

  function initReadMore() {
    const toggles = document.querySelectorAll<HTMLButtonElement>('.rec-toggle');
    toggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.rec-card');
        if (!card) return;
        const extra = card.querySelector<HTMLElement>('.rec-extra');
        const label = btn.querySelector('.rec-toggle-text');
        if (!extra || !label) return;

        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        extra.setAttribute('aria-hidden', String(expanded));
        extra.classList.toggle('is-open', !expanded);
        label.textContent = expanded ? 'Ver más' : 'Ver menos';
      });
    });
  }

  function init() {
    initRecReveal();
    initReadMore();
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
