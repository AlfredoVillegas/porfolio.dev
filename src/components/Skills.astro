---
import Cloudinary from './icons/Cloudinary.astro';
import Docker from './icons/Docker.astro';
import Express from './icons/Express.astro';
import Git from './icons/Git.astro';
import GitHub from './icons/GitHub.astro';
import Javascript from './icons/JavascriptIcon.astro';
import Jest from './icons/Jest.astro';
import Nestjs from './icons/Nestjs.astro';
import NextJS from './icons/NextJS.astro';
import NodeIcon from './icons/NodeIcon.astro';
import Postgre from './icons/PostgreSql.astro';
import React from './icons/React.astro';
import Tailwind from './icons/Tailwind.astro';
import Teeam from './icons/Teeam.astro';
import Typescript from './icons/TypeScriptIcon.astro';
import cloude from './icons/cloude.astro';
import cursor from './icons/cursor.astro';

const TAGS = {
  JAVASCRIPT: {
    name: 'JavaScript',
    icon: Javascript
  },
  TYPESCRIPT: {
    name: 'TypeScript',
    icon: Typescript
  },
  Node: {
    name: 'Node.js',
    icon: NodeIcon
  },
  NEST: {
    name: 'Nest.js',
    icon: Nestjs
  },
  EXPRESS: {
    name: 'Express.js',
    icon: Express
  },
  NEXT: {
    name: 'Next.js',
    icon: NextJS
  },
  REACT: {
    name: 'React.js',
    icon: React
  },
  TAILWIND: {
    name: 'Tailwind CSS',
    icon: Tailwind
  },
  JEST: {
    name: 'Jest-Testing',
    icon: Jest
  },
  POSTGRE: {
    name: 'PostgreSQL',
    icon: Postgre
  },
  CLOUDINARY: {
    name: 'Cloudinary',
    icon: Cloudinary
  },
  GIT: {
    name: 'Git',
    icon: Git
  },
  GITHUB: {
    name: 'GitHub',
    icon: GitHub
  },
  DOCKER: {
    name: 'Docker',
    icon: Docker
  },
  // TEAM: {
  //   name: 'En equipo',
  //   icon: Teeam
  // },
  CLAUDE: {
    name: 'Claude Code',
    icon: cloude
  },
  CURSOR: {
    name: 'Cursor',
    icon: cursor
  }
};
---

<div>
  <ul class="flex flex-wrap gap-4">
    {
      Object.values(TAGS).map(tag => (
        <li>
          <div class="skill-tag flex gap-x-2 items-center">
            <tag.icon class="size-6" />
            <span>{tag.name}</span>
          </div>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .skill-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #484848;
    background: #ffffff;
    border: 1px solid rgba(226, 190, 188, 0.6); /* #e2bebc */
    border-radius: 999px;
    padding: 0.5rem 1.2rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    white-space: nowrap;
  }
  .skill-tag:hover {
    background: #fff0f2;
    color: #b52330;
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 15px -3px rgba(181, 35, 48, 0.1), 0 4px 6px -4px rgba(181, 35, 48, 0.1);
    border-color: #f43f5e;
  }
</style>
