---
import Layout from '@/layouts/Layout.astro';

import AboutMe from '@/components/AboutMe.astro';
import Badge from '@/components/Badge.astro';
import Briefcase from '@/components/icons/Briefcase.astro';
import CodeIcon from '@/components/icons/Code.astro';
import Experience from '@/components/Experience.astro';
import GitHubIcon from '@/components/icons/GitHub.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import ProfileCheck from '@/components/icons/ProfileCheck.astro';
import Projects from '@/components/Projects.astro';
import SectionContainer from '@/components/SectionContainer.astro';
import SocialPill from '@/components/SocialPill.astro';
import CV from '@/components/icons/CV.astro';
import Recomendation from '@/components/Recomendation.astro';
import Skills from '@/components/Skills.astro';
import SkillsIcon from '@/components/icons/SkillsIcon.astro';
---

<Layout
  title="Porfolio de Alfredo - Desarrollador Fullstack web"
  description="Alfredo Villegas. Desarrollador con experiencia para crear tu aplicación web"
>
  <main>
    <SectionContainer class="pt-24 pb-16 md:py-36 max-w-6xl px-4 md:px-6">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
        <div class="md:col-span-7 space-y-6 order-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="font-['Space_Grotesk'] text-xs font-bold uppercase tracking-widest text-[#006a62] bg-[#7af7e8]/30 px-3 py-1 rounded-full border border-[#006a62]/20">
              Software Developer
            </span>
          </div>

          <h1 class="font-['Plus_Jakarta_Sans'] text-5xl md:text-6xl font-bold text-[#261817] leading-tight">
            Hola, soy <span class="relative inline-block text-[--primary]" id="hero-name">
              Alfredo
              <img
                src="/subra.webp"
                class="absolute top-[0] left-0 w-full h-auto underline-path pointer-events-none -z-10"
                alt=""
                aria-hidden="true"
              />
            </span>
          </h1>

          <h2 class="font-['Plus_Jakarta_Sans'] text-xl md:text-2xl text-[#484848] max-w-[600px] leading-relaxed">
            <span class="font-semibold text-[#261817]">Desarrollador web Full-stack</span> 
            con experiencia trabajando en equipo bajo metodologías ágiles, brindando soluciones y colaborando estrechamente con el cliente.
          </h2>

          <div class="flex flex-col sm:flex-row gap-4 mt-10 flex-wrap items-stretch sm:items-center sm:justify-start">
            <a 
              href="#experiencia" 
              class="group inline-flex w-full sm:w-auto items-center justify-center gap-2 px-6 py-3 text-base font-bold text-white bg-[--primary] rounded-xl shadow-lg hover:opacity-85 transition-all duration-300 hover:shadow-xl active:scale-95"
            >
              Ver Experiencia
              <svg class="size-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a 
              href="https://drive.google.com/file/d/1lctuCumpw-PYYNqn8H-A6oHcIOyRjZdw/view?usp=drive_link" 
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full sm:w-auto items-center justify-center px-6 py-3 text-base font-bold text-gray-900 border-2  rounded-xl shadow-sm hover:bg-gray-900/5 transition-all duration-300 active:scale-95"
            >
              <CV class="size-5 mr-2" />
              Descargar CV
            </a>
          </div>

          <div class="pt-4">
            <h3 class="font-['Space_Grotesk'] text-sm font-bold uppercase/ tracking-widest text-[#484848]/80 mb-4">
              Conecta Conmigo
            </h3>
            <nav class="flex gap-3 flex-wrap">
              <SocialPill href="https://linkedin.com/in/alfredo-villegas-backend/">
                <LinkedInIcon class="size-5" />
                LinkedIn
              </SocialPill>
              <SocialPill href="https://github.com/alfredovillegas">
                <GitHubIcon class="size-5" />
                GitHub
              </SocialPill>
              <SocialPill href="mailto:alfreddovillegas@gmail.com">
                <MailIcon class="size-5" />
                Email
              </SocialPill>
            </nav>
          </div>
        </div>

        <div class="md:col-span-5 flex justify-center md:justify-end order-2">
          <div class="relative w-[300px] h-[360px] md:w-[400px] md:h-[440px]">
            <!-- Glow Cian a la derecha -->
            <div class="absolute top-[50%] -right-[1%] w-[90%] aspect-square bg-[#b0e0e6] rounded-full mix-blend-multiply filter blur-[90px] opacity-80 -z-30 pointer-events-none"></div>
            <!-- Glow Rosa a la izquierda -->
            <div class="absolute -top-[5%] left-[5%] w-[90%] aspect-square bg-[#f9c4cc] rounded-full mix-blend-multiply filter blur-[90px] opacity-70 -z-30 pointer-events-none"></div>
            <!-- 2. Patrón de puntos -->
            <div class="absolute top-[2%] right-[-20%] w-48 h-48 opacity-40 -z-20 pointer-events-none">
              <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <pattern id="dot-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                    <circle fill="#cbd5e1" cx="2" cy="2" r="1.5"></circle>
                  </pattern>
                </defs>
                <rect x="0" y="0" width="100%" height="100%" fill="url(#dot-pattern)"></rect>
              </svg>
            </div>
            <!-- 3. Circulo rojo -->
            <div class="absolute top-[10%] left-[5%] w-[85%] aspect-square rounded-full -z-10" style="background: radial-gradient(circle at 45% 40%, #ffffff 0%, #fff0f2 25%, #fdd0d8 50%, #f9899e 72%, #f43f5e 88%, transparent 100%); filter: blur(2px);"></div>
            <!-- 4. Línea Curva (Arco) Cian -->
            <div class="absolute top-[41%] -right-[15%] w-[100%] aspect-square -z-20 pointer-events-none">
              <svg viewBox="0 0 200 200" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="arc-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#7ecfc9" stop-opacity="0.7"/>
                    <stop offset="40%" stop-color="#b0e0e6" stop-opacity="0.5"/>
                    <stop offset="70%" stop-color="#d4efef" stop-opacity="0.25"/>
                    <stop offset="100%" stop-color="#e0f7fa" stop-opacity="0.05"/>
                  </linearGradient>
                </defs>
                <circle cx="100" cy="100" r="98" fill="none" stroke="url(#arc-gradient)" stroke-width="1.5"/>
              </svg>
            </div>
            <!-- 5. Estrella/Destello Rojo Flotante -->
            <div class="absolute top-[25%] left-[0%] text-[#f43f5e] animate-float pointer-events-none z-[5]">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 0C12 0 12 10.5 24 12C24 12 12 13.5 12 24C12 24 12 13.5 0 12C0 12 12 10.5 12 0Z" />
              </svg>
            </div>
            <!-- 6. Medalla Flotante de Código </> -->
            <div class="absolute top-[15%] right-[10%] bg-white rounded-full w-14 h-14 md:w-16 md:h-16 flex items-center justify-center shadow-[0_15px_35px_-5px_rgba(0,0,0,0.1)] z-20 animate-float-delayed">
              <span class="text-[#f43f5e] font-bold text-lg md:text-xl tracking-tighter">&lt;/&gt;</span>
            </div>
            <div class="relative w-full h-full flex items-end justify-center z-10 mt-[-2.5rem]">
              <div class="photo-frame relative w-[240px] h-[320px] md:w-[280px] md:h-[380px] transition-transform hover:scale-[1.02] duration-500">
                <div class="absolute inset-0 rounded-xl overflow-hidden  bg-transparent ">
                  <img
                    class="w-full h-full object-cover object-top rounded-xl/ transition-all duration-700 ease-in-out"
                    src="/yo-no-bg.webp"
                    alt="Alfredo Villegas photo"
                  />
                </div>
              </div>
            </div>
            <!-- 8. Tarjeta de Experiencia -->
            <div class="absolute bottom-[8%]/ bottom-[14%] -right-[5%] z-30 animate-fade-in-up">
              <div class="relative group overflow-hidden rounded-xl shadow-xl border border-[#e2bebc]/30">
                <div class="spin-ring absolute inset-[-100%] z-0"></div>
                <div class="relative z-10 bg-white m-[2px] rounded-[10px] px-4 py-3 flex items-center gap-3">
                  <div class="w-10 h-10 bg-[#FF5A5F]/10 rounded-lg flex items-center justify-center text-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f43f5e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-briefcase">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M3 9a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2l0 -9" />
                      <path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2" />
                      <path d="M12 12l0 .01" />
                      <path d="M3 13a20 20 0 0 0 18 0" />
                    </svg>
                  </div>
                  <div class="text-sm">
                    <p class="font-bold text-[#261817] whitespace-nowrap">+3 años de experiencia</p>
                    <p class="text-[#484848] text-xs whitespace-nowrap">Desarrollando sistemas web</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </SectionContainer>

    <SectionContainer id="experiencia" class="py-0 md:py-0 max-w-full !px-0">
      <Experience />
      <Recomendation />
    </SectionContainer>

    <!-- Interactive CTA Section: Full-Bleed -->
    <div class="w-full overflow-hidden relative z-10">
      <!-- Top mosaic bar -->
      <div class="w-full grid grid-cols-8 md:grid-cols-16 h-5 overflow-hidden">
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#F46C81]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#F46C81]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#F46C81]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#F46C81]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
      </div>

      <!-- Central content block -->
      <div class="bg-[#f0f7f6] w-full border-y border-[#e2bebc]/20">
        <div class="max-w-5xl mx-auto px-6 md:px-8 py-14 md:py-20 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
          <div class="max-w-2xl">
            <h3 class="font-['Plus_Jakarta_Sans'] text-2xl md:text-3xl lg:text-[2.2rem] font-bold text-[#261817] leading-tight tracking-tight">
              Disponible para nuevos desafíos <span class="font-['Newsreader'] italic font-normal text-[#f43f5e]">Full-stack</span> y proyectos en 2026
            </h3>
          </div>
          <div class="flex flex-col items-start md:items-end gap-3 flex-shrink-0">
            <a
              href="https://drive.google.com/file/d/1lctuCumpw-PYYNqn8H-A6oHcIOyRjZdw/view?usp=drive_link"
              target="_blank"
              rel="noopener"
              class="bg-[#141413] text-white font-['Work_Sans'] font-semibold px-6 py-4 rounded-lg flex items-center gap-3 hover:bg-[#261817] transition-all hover:scale-[1.03] active:scale-95 shadow-lg shadow-black/10 group text-sm md:text-base animate-pulse hover:animate-none border border-[#e2bebc]/30"
            >
              <svg class="size-4 transition-transform group-hover:translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
              Descargar CV
            </a>
            <a
              href="mailto:alfreddovillegas@gmail.com"
              class="font-['Space_Grotesk'] text-xs font-bold text-[#006a62] hover:text-[#b52330] transition-colors underline underline-offset-4"
            >
              o escribir a alfreddovillegas@gmail.com
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom mosaic bar -->
      <div class="w-full grid grid-cols-8 md:grid-cols-16 h-5 overflow-hidden">
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#e2bebc]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#e2bebc]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#e2bebc]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
        <div class="h-full bg-gradient-to-r from-[#f43f5e] to-[#e2bebc]"></div>
        <div class="h-full bg-[#261817]"></div>
        <div class="h-full bg-[#006a62]"></div>
        <div class="h-full bg-[#f0f7f6]"></div>
      </div>
    </div>

    <!-- Proyectos: full-bleed dark section -->
    <div id="proyectos" class="w-full bg-[#141413] relative overflow-hidden">
      <!-- Decorative blobs -->
      <div class="max-w-5xl mx-auto px-4 md:px-6 py-16 md:py-24 relative z-10">
        <span class="font-['Space_Grotesk'] text-[0.7rem] font-bold uppercase tracking-[0.18em] text-[#7af7e8] block mb-3 text-center">
          ● Proyectos
        </span>
        <h2 class="font-['Plus_Jakarta_Sans'] text-3xl md:text-4xl font-bold mt-3 mb-3 flex gap-x-3 items-center justify-center text-white">
          <CodeIcon class="size-8 text-[#f43f5e]" />
          Proyectos Destacados
        </h2>
        <p class="font-['Plus_Jakarta_Sans'] text-[#a89997] text-base mb-12 max-w-xl text-center mx-auto">
          Como una oportunidad de aprender, construir y crear valor.
        </p>
        <Projects />
      </div>
    </div>

    <SectionContainer class="border-t border-[#e2bebc]/30 py-12 md:py-20" id="skills">
      <span class="font-['Space_Grotesk'] text-[0.7rem] font-bold uppercase tracking-[0.18em] text-[#006a62] block mb-3">
        ● Tecnologías
      </span>
      <h2 class="font-['Plus_Jakarta_Sans'] text-3xl md:text-4xl font-bold mb-10 flex gap-x-3 items-center text-[#261817]">
        <SkillsIcon class="size-8 text-[#f43f5e]" />
         Stack Tecnico
      </h2>
      <Skills />
    </SectionContainer>

    <SectionContainer id="sobre-mi" class="border-t border-[#e2bebc]/30 py-12 md:py-20 max-w-5xl">
      <span class="font-['Space_Grotesk'] text-[0.7rem] font-bold uppercase tracking-[0.18em] text-[#006a62] block mb-3 text-center">
        ● Conóceme
      </span>
      <h2 class="font-['Plus_Jakarta_Sans'] text-3xl md:text-4xl font-bold mb-14 flex gap-x-3 items-center justify-center text-[#261817]">
        <ProfileCheck class="size-8 text-[#f43f5e]" />
         Sobre mi
      </h2>
      <AboutMe />
    </SectionContainer>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const heroName = document.getElementById('hero-name');
    if (!heroName) return;

    const underlinePath = heroName.querySelector('.underline-path') as HTMLImageElement | null;
    if (!underlinePath) return;

    const replayAnimation = () => {
      underlinePath.style.animation = 'none';
      // Force reflow to reset the animation
      void underlinePath.getBoundingClientRect();
      underlinePath.style.animation = '';
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            replayAnimation();
          }
        });
      },
      { threshold: 0.6 }
    );

    observer.observe(heroName);
  });
</script>

<style>
  .spin-ring {
    background: conic-gradient(
      from 0deg,
      #ff5a5f 0deg,
      #b52330 90deg,
      #006a62 180deg,
      #7af7e8 270deg,
      #ff5a5f 360deg
    );
    filter: blur(3px);
    opacity: 1;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    animation: spin-border 6s linear infinite;
  }

  .group {
    overflow: hidden;
  }

  .photo-frame:hover .spin-ring {
    animation-duration: 10s;
  }

  @keyframes spin-border {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animaciones flotantes para las figuras decorativas */
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float 4s ease-in-out 2s infinite;
  }

  .underline-path {
    animation: underline-draw 0.8s ease-out forwards;
    transform-origin: left;
  }

  @keyframes underline-draw {
    from {
      transform: scaleX(0);
      opacity: 0;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }
</style>
